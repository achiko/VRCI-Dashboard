{
  "name": "web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "DATABASE_URL=${DATABASE_URL:-postgresql://user:password@localhost:5432/db} prisma generate && next build",
    "start": "next start",
    "lint": "next lint",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "test:coverage": "bun test --coverage",
    "postinstall": "prisma generate",
    "contracts:gen": "for f in ./src/contracts/schemas/*.json; do bunx dedot typink -m $f -o ./src/lib/contracts; done"
  },
  "dependencies": {
    "@bprogress/core": "^1.3.4",
    "@bprogress/next": "^3.2.12",
    "@dedot/chaintypes": "^0.166.0",
    "@polkadot/api": "^16.5.2",
    "@polkadot/api-contract": "^16.5.2",
    "@polkadot/keyring": "^13.5.7",
    "@polkadot/react-identicon": "^3.16.1",
    "@polkadot/util": "^13.5.7",
    "@prisma/client": "^6.19.0",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-progress": "^1.1.7",
    "@radix-ui/react-separator": "^1.1.7",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tanstack/react-query": "^5.90.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dedot": "^0.18.3",
    "ethers": "^6.15.0",
    "lucide-react": "^0.546.0",
    "next": "^15.5.5",
    "next-themes": "^0.4.6",
    "polkadot-ui": "latest",
    "prisma": "^6.19.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-toastify": "^11.0.5",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.3.0",
    "typink": "^0.5.1",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "jest": "^30.2.0",
    "node-mocks-http": "^1.17.2",
    "tailwindcss": "^4",
    "ts-jest": "^29.4.5",
    "tw-animate-css": "^1.3.4",
    "typescript": "^5"
  }
}
