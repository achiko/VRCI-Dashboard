// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// User wallets for off-chain persistence
model Wallet {
  id        String   @id @default(cuid())
  address   String   @unique
  chainId   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  logs      Log[]
  
  @@index([address])
  @@index([chainId])
}

// Contract interaction logs
model Log {
  id          String   @id @default(cuid())
  walletId    String
  wallet      Wallet   @relation(fields: [walletId], references: [id], onDelete: Cascade)
  contract    String
  method      String
  txHash      String?
  status      String   // 'pending' | 'success' | 'failed'
  data        Json?
  createdAt   DateTime @default(now())
  
  @@index([walletId])
  @@index([contract])
  @@index([txHash])
  @@index([createdAt])
}

// Admin-managed tokens/coins
model Token {
  id          String   @id @default(cuid())
  symbol      String   @unique
  name        String
  description String?
  enabled     Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@index([symbol])
  @@index([enabled])
}

// Whitelisted wallet addresses for platform access
model Whitelist {
  id        String   @id @default(cuid())
  address   String   @unique
  addedBy   String?  // Address of admin who added this wallet
  note      String?  // Optional note about why this wallet is whitelisted
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  @@index([address])
}
